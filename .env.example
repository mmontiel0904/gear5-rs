# Copy to .env for local dev. Real secrets must come from the environment, not config files.

DATABASE_URL=postgres://gear5:gear5@localhost:5432/gear5
GEAR5_SERVER__BIND=0.0.0.0:8080
GEAR5_IMAGES__DIR=./var/images
GEAR5_SCRAPE__ENABLED=true
GEAR5_SCRAPE__RUN_AT_STARTUP=false
GEAR5_SCRAPE__CRON_HOUR_UTC=4
GEAR5_SCRAPE__CONCURRENCY=4
GEAR5_SCRAPE__USER_AGENT=gear5-rs/0.1
GEAR5_SCRAPE__STALE_AFTER_HOURS=36
RUST_LOG=info,gear5_api=debug,gear5_core=debug
